{
  "compilerOptions": {
    "declaration": true,
    "noFallthroughCasesInSwitch": true,
    "composite": true,
    "module": "esnext",
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "inlineSourceMap": true,
    "allowJs": true,
    "jsx": "preserve",
    "noEmit": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0", // Ignore deprecations for version 6.0 because "modeResolution" and "baseUrl" are deprecated in TS 7.0
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strictPropertyInitialization": false,
    "baseUrl": "src",
    "plugins": [
      {
        "name": "next"
      }
    ],
    // needed for jest
    "paths": {
      "@src": ["./src"],
      "@util": ["./src/util"]
    },
    "types": ["./svgr.d.ts", "node", "jest"],
    "incremental": true
  },
  "include": [
    // Cypress.scannerCallback
    "./cypress/global.d.ts",
    "./scripts/validateEnvs.js",
    "./global.d.ts",
    "./next-env.d.ts",
    "./svgr.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "./dist/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
